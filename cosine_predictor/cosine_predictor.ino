#include <math.h>    // cos()

// ------------------------------------------------------------------
// Tensor arena
// The model uses Dense(16) x2 -> Dense(1) with int8 weights.
// 4 KB is comfortable; tune downward if you want to report minimum.
// ------------------------------------------------------------------
constexpr int kArenaSize = 4 * 1024;
static uint8_t tensor_arena[kArenaSize];

// ------------------------------------------------------------------
// TFLite Micro globals
// ------------------------------------------------------------------
static const tflite::Model*      tfl_model    = nullptr;
static tflite::MicroInterpreter* interpreter  = nullptr;
static TfLiteTensor*             input_tensor = nullptr;
static TfLiteTensor*             output_tensor= nullptr;

// Quantization parameters read at runtime from the tensors
float in_scale,  out_scale;
int   in_zp,     out_zp;

bool model_ready = false;

// ------------------------------------------------------------------
// Sweep parameters
// ------------------------------------------------------------------
constexpr int   STEPS       = 80;              // points per period
constexpr float STEP_SIZE   = 2.0f * M_PI / STEPS;
constexpr int   PERIODS     = 2;               // sweep 2 full periods
constexpr int   TOTAL_STEPS = STEPS * PERIODS;

// ------------------------------------------------------------------
void setup() {
  Serial.begin(115200);
  delay(1500);   // give Serial Monitor time to open

  Serial.println();
  Serial.println("=== Cosine Wave Predictor — Startup ===");

  // 1. Load model from Flash
  tfl_model = tflite::GetModel(g_model);
  if (tfl_model->version() != TFLITE_SCHEMA_VERSION) {
    Serial.print("ERROR: Schema mismatch — model=");
    Serial.print(tfl_model->version());
    Serial.print("  lib=");
    Serial.println(TFLITE_SCHEMA_VERSION);
    return;
  }

  // 2. Op resolver — register ONLY the ops this model uses.
  //    Dense layers map to FullyConnected; activations are Relu.
  //    Using MicroMutableOpResolver instead of AllOpsResolver saves Flash.
  static tflite::MicroMutableOpResolver<2> resolver;
  resolver.AddFullyConnected();
  resolver.AddRelu();

  // 3. Build interpreter
  static tflite::MicroInterpreter static_interp(
      tfl_model, resolver, tensor_arena, kArenaSize);
  interpreter = &static_interp;

  // 4. Allocate tensors
  TfLiteStatus status = interpreter->AllocateTensors();
  if (status != kTfLiteOk) {
    Serial.print("ERROR: AllocateTensors failed, status=");
    Serial.println((int)status);
    return;
  }

  // 5. Grab input / output tensor pointers
  input_tensor  = interpreter->input(0);
  output_tensor = interpreter->output(0);

  // 6. Read quantization parameters
  in_scale  = input_tensor->params.scale;
  in_zp     = input_tensor->params.zero_point;
  out_scale = output_tensor->params.scale;
  out_zp    = output_tensor->params.zero_point;

  // ------------------------------------------------------------------
  // Startup diagnostics (required by section 3.3 point 5)
  // ------------------------------------------------------------------
  Serial.println();
  Serial.println("--- Startup Diagnostics ---");
  Serial.print("g_model size (bytes)    : "); Serial.println(g_model_len);
  Serial.print("Arena used (bytes)      : "); Serial.println(interpreter->arena_used_bytes());
  Serial.print("Arena total (bytes)     : "); Serial.println(kArenaSize);
  Serial.print("Input  scale            : "); Serial.println(in_scale,  8);
  Serial.print("Input  zero_point       : "); Serial.println(in_zp);
  Serial.print("Output scale            : "); Serial.println(out_scale, 8);
  Serial.print("Output zero_point       : "); Serial.println(out_zp);
  Serial.println("---------------------------");
  Serial.println();
  Serial.println("Starting Serial Plotter output...");
  Serial.println("Predicted,Actual");   // header for Serial Plotter labels
  delay(500);

  model_ready = true;
}

// ------------------------------------------------------------------
void loop() {
  if (!model_ready) {
    delay(1000);
    return;
  }

  // Sweep x from 0 to PERIODS * 2π
  for (int step = 0; step < TOTAL_STEPS; step++) {
    float x = step * STEP_SIZE;

    // ── 1. Quantize float x → int8 ─────────────────────────────────
    //   int8_val = round(x / scale) + zero_point,  clamped to [-128, 127]
    int32_t x_q32 = (int32_t)roundf(x / in_scale) + in_zp;
    if (x_q32 >  127) x_q32 =  127;
    if (x_q32 < -128) x_q32 = -128;
    input_tensor->data.int8[0] = (int8_t)x_q32;

    // ── 2. Run inference ────────────────────────────────────────────
    if (interpreter->Invoke() != kTfLiteOk) {
      Serial.println("ERROR: Invoke() failed");
      delay(1000);
      return;
    }

    // ── 3. Dequantize int8 output → float ──────────────────────────
    //   float_val = (int8_val - zero_point) * scale
    int8_t y_q      = output_tensor->data.int8[0];
    float  y_pred   = ((float)y_q - (float)out_zp) * out_scale;

    // ── 4. Ground truth ─────────────────────────────────────────────
    float  y_actual = cosf(x);

    // ── 5. Serial Plotter output ────────────────────────────────────
    //    Format: "predicted,actual\n"
    //    Serial Plotter splits on comma and plots both as separate traces.
    Serial.print(y_pred,   4);
    Serial.print(",");
    Serial.println(y_actual, 4);

    delay(25);   // ~40 Hz refresh — smooth without flooding the plotter
  }

  // Brief pause between sweeps so the plotter shows a clear restart
  delay(200);
}
